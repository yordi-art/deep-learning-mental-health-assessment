{
  "name": "Mental Health Assessment AI",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  // Auto-install pip dependencies when container starts
  "postCreateCommand": "pip install -r requirements.txt",

  // VS Code extensions auto-installed every time
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "amazonwebservices.amazon-q-vscode"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  // Forward Streamlit port automatically
  "forwardPorts": [8501],
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openBrowser"
    }
  }
}
